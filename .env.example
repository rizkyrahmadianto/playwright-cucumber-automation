# ====================================

# Application Environment Configuration

# ====================================

# Base URL aplikasi yang akan diuji

BASE_URL=https://example.com

# Environment name

ENV=staging

# ====================================

# Browser Configuration

# ====================================

# Browser yang digunakan (chromium | firefox | webkit)

BROWSER=chromium

# Jalankan browser secara headless atau tidak

HEADLESS=true

# ====================================

# Timeout Configuration (milliseconds)

# ====================================

GLOBAL_TIMEOUT=30000
STEP_TIMEOUT=20000

# ====================================

# Test Account (Example Only)

# ====================================

TEST_USER_EMAIL=[test@example.com](mailto:test@example.com)
TEST_USER_PASSWORD=examplepassword

# ====================================

# Automation Behaviour

# ====================================

# Screenshot saat test gagal

SCREENSHOT_ON_FAILURE=true

# Record video saat menjalankan test

VIDEO_RECORDING=false
